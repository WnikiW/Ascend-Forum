@model ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="d-flex flex-column justify-content-center align-items-center text-center" style="height:70vh;">
    <h1 class="display-4 fw-bold text-secondary">Error</h1>
    <p class="text-muted mb-3">
        An unexpected error occurred.
    </p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">
            Request ID: <strong>@Model.RequestId</strong>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary mt-3 px-4">
        Go Home
    </a>
</div>