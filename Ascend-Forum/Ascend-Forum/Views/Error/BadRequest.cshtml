@{
    ViewData["Title"] = "400 Bad Request";
}

<div class="d-flex flex-column justify-content-center align-items-center text-center" style="height:70vh;">
    <h1 class="display-1 fw-bold text-warning">400</h1>
    <h3 class="mb-3">Bad Request</h3>
    <p class="text-muted mb-4">
        Your request could not be processed. Please try again.
    </p>

    <a asp-controller="Home" asp-action="Index" class="btn btn-warning px-4">
        Go Home
    </a>
</div>