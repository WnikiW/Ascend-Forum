@{
    ViewData["Title"] = "500 Server Error";
}

<div class="d-flex flex-column justify-content-center align-items-center text-center" style="height:70vh;">
    <h1 class="display-1 fw-bold text-danger">500</h1>
    <h3 class="mb-3">Something went wrong</h3>
    <p class="text-muted mb-4">
        An unexpected error occurred on our side. Please try again later.
    </p>

    <a asp-controller="Home" asp-action="Index" class="btn btn-danger px-4">
        Go Home
    </a>
</div>