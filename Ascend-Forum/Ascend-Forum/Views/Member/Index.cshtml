@model Ascend_Forum.Core.Models.Member.MemberListPageModel

<div class="text-center">
    <h1>
        @ViewData["Title"]
    </h1>
</div>

<div class="container-fluid my-5">
    <div class="row justify-content-center mb-4">
        <div class="col-md-8">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label for="minPostCount" class="form-label">Minimum Posts</label>
                    <input type="number" name="minPostCount" id="minPostCount" class="form-control" placeholder="e.g. 5" value="@Model.MinPostCount" />
                </div>
                <div class="col-md-5">
                    <label for="minReactionCount" class="form-label">Minimum Reactions</label>
                    <input type="number" name="minReactionCount" id="minReactionCount" class="form-control" placeholder="e.g. 10" value="@Model.MinReactionCount" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>
    @if (Model.Members.Any())
    {
        <div class="row">
            <div class="col">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th scope="col">Ascend Name</th>
                                <th scope="col">Posts Count</th>
                                <th scope="col">Reactions Received</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var member in Model.Members)
                            {
                                <tr>
                                    <td>@(member.AscendName)</td>
                                    <td>@(member.PostCount)</td>
                                    <td>@(member.CommentReactionCount)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.CurrentPage - 1)" 
                           asp-route-minPostCount="@Model.MinPostCount" 
                           asp-route-minReactionCount="@Model.MinReactionCount">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-pageNumber="@i" 
                               asp-route-minPostCount="@Model.MinPostCount" 
                               asp-route-minReactionCount="@Model.MinReactionCount">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.CurrentPage + 1)" 
                           asp-route-minPostCount="@Model.MinPostCount" 
                           asp-route-minReactionCount="@Model.MinReactionCount">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="d-flex justify-content-center align-items-center mt-5">
            <div class="text-center p-5 " style="max-width: 500px;">
                <h4 class="fw-bold mb-2">No Members Found</h4>
                <p class="text-muted fst-italic mb-0">No members match your current filters.</p>
            </div>
        </div>
    }
</div>
